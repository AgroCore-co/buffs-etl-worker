# RabbitMQ Configuration
# URL de conexão AMQP com RabbitMQ
# 
# Desenvolvimento LOCAL (sem Docker):
#   RABBITMQ_URL=amqp://admin:admin@localhost:5672/
#
# Desenvolvimento COM Docker (mesmo que API principal):
#   RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672/
#   (usa hostname interno 'rabbitmq' do docker-compose)
#
RABBITMQ_URL=amqp://admin:admin@localhost:5672/

# Nome da fila que o worker vai consumir
RABBITMQ_QUEUE=excel_processing_queue

# Caminho base para os uploads de planilhas.
# O NestJS envia apenas o nome do arquivo na mensagem;
# o worker resolve o caminho completo: UPLOAD_BASE_PATH + filename
#
# Desenvolvimento LOCAL (Go nativo no host):
#   UPLOAD_BASE_PATH=../buffs-api/temp/uploads
#
# Docker (bind mount compartilhado):
#   UPLOAD_BASE_PATH=/shared/uploads
#
UPLOAD_BASE_PATH=../buffs-api/temp/uploads

# PostgreSQL Configuration
# Connection string para lookup de brincos (brinco → UUID)
#
# Se não configurado, a resolução de brinco→UUID fica desativada.
# Isso significa que abas dependentes (Pesagens, Sanitário, etc.)
# não conseguirão resolver as FKs.
#
# Formato: postgresql://user:password@host:port/database
#
# Desenvolvimento LOCAL (Supabase ou PostgreSQL local):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buffs_db
#
# Docker (PostgreSQL no docker-compose da API):
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/buffs_db
#
# Supabase (exemplo):
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
#
DATABASE_URL=
