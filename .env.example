# ========================================
# ETL BUFFS - Variáveis de Ambiente
# ========================================
# Copie este arquivo para .env e preencha os valores.
#
# Todas as variáveis são prefixadas com BUFFS_ETL_.
# ========================================

# ── Ambiente ─────────────────────────────────────────────────────────────────
# production | development (afeta formato de logs)
BUFFS_ETL_ENV=development

# ── Servidor HTTP (Fiber) ────────────────────────────────────────────────────
BUFFS_ETL_PORT=3001
BUFFS_ETL_READ_TIMEOUT=30s
BUFFS_ETL_WRITE_TIMEOUT=60s

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Connection string do mesmo banco da BUFFS API principal.
#
# Desenvolvimento LOCAL (Supabase):
#   BUFFS_ETL_DB_URL=postgresql://postgres.xxx:password@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Docker (PostgreSQL local):
#   BUFFS_ETL_DB_URL=postgresql://postgres:postgres@postgres:5432/buffs_db
#
BUFFS_ETL_DB_URL=postgresql://postgres:postgres@localhost:5432/buffs_db
BUFFS_ETL_DB_MAX_CONNS=20
BUFFS_ETL_DB_MIN_CONNS=5
BUFFS_ETL_DB_MAX_CONN_LIFETIME=30m

# ── Redis (Asynq - jobs assíncronos) ────────────────────────────────────────
BUFFS_ETL_REDIS_URL=redis://localhost:6379

# ── Autenticação JWT ────────────────────────────────────────────────────────
# Secret do JWT do Supabase (mesmo usado pela BUFFS API).
BUFFS_ETL_JWT_SECRET=your-supabase-jwt-secret-here

# ── Upload ───────────────────────────────────────────────────────────────────
BUFFS_ETL_MAX_FILE_SIZE=52428800
BUFFS_ETL_TEMP_DIR=./temp/uploads

# ── Export ───────────────────────────────────────────────────────────────────
BUFFS_ETL_INCLUDE_REF_SHEET=true

# ── Worker Asynq ────────────────────────────────────────────────────────────
BUFFS_ETL_WORKER_CONCURRENCY=5
BUFFS_ETL_ASYNC_THRESHOLD=1000

# ── Rate Limiting ────────────────────────────────────────────────────────────
BUFFS_ETL_RATE_LIMIT_IMPORTS_PER_HOUR=10
